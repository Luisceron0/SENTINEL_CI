# File Purpose:
# - Document required environment variables with safe placeholder values and provenance.
#
# Key Security Considerations:
# - No real secrets are stored here.
# - All secret values must come from secure secret managers and deployment environment settings.
#
# OWASP 2025 Categories Addressed:
# - A02, A04, A08

# Supabase
# Source: Supabase project settings
SUPABASE_URL=https://your-project-ref.supabase.co
# Source: Supabase API settings (public key)
SUPABASE_ANON_KEY=replace_with_supabase_anon_key
# Source: Supabase API settings (server-only secret)
SUPABASE_SERVICE_ROLE_KEY=replace_with_supabase_service_role_key

# GitHub OAuth (configured in Supabase Auth provider)
# Source: GitHub OAuth App settings
GITHUB_OAUTH_CLIENT_ID=replace_with_github_oauth_client_id
# Source: GitHub OAuth App settings (secret)
GITHUB_OAUTH_CLIENT_SECRET=replace_with_github_oauth_client_secret

# DefectDojo integration
# Source: DefectDojo deployment URL
DEFECTDOJO_URL=https://your-defectdojo-instance.example.com
# Source: DefectDojo API token settings
DEFECTDOJO_API_KEY=replace_with_defectdojo_api_key

# Sentinel internal settings
# Source: Generated and stored in deployment secrets manager
SENTINEL_WEBHOOK_SECRET=replace_with_default_webhook_hmac_secret
# Source: Public deployment URL
NEXT_PUBLIC_DASHBOARD_URL=https://sentinel-ci.example.com
# Source: API deployment URL
SENTINEL_API_ENDPOINT=https://sentinel-ci.example.com/api

# Optional operational settings
# Source: Deployment environment config
LOG_LEVEL=INFO
ENVIRONMENT=development
